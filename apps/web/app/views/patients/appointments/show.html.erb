<div class="min-h-screen px-6 py-10">
  <div class="max-w-4xl mx-auto bg-white/80 backdrop-blur-sm shadow-xl rounded-2xl border border-gray-100 p-8">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
      <h1 class="text-3xl font-semibold text-gray-800">Appointment Details</h1>
      <div class="flex flex-wrap gap-3">
        <%= link_to 'Back',
              patient_appointments_path,
              class: 'inline-flex items-center rounded-xl bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium px-4 py-2 transition-colors duration-200' %>

        <% if @appointment.can_join_room? %>
          <%= link_to 'Join Room',
                patient_appointment_room_path(@appointment.id),
                class: 'inline-flex items-center rounded-xl bg-green-600 hover:bg-green-700 text-white font-medium px-4 py-2 transition-colors duration-200 shadow-sm' %>
        <% end %>

        <% if @appointment.can_be_edited? %>
          <%= link_to 'Edit',
                patient_edit_appointment_path(@appointment.id),
                class: 'inline-flex items-center rounded-xl bg-yellow-500 hover:bg-yellow-600 text-white font-medium px-4 py-2 transition-colors duration-200 shadow-sm' %>

          <%= button_to 'Cancel',
                patient_cancel_appointment_path(@appointment.id),
                method: :delete,
                data: { turbo_confirm: 'Are you sure?' },
                class: 'text-red-600 hover:text-red-800 font-medium underline cursor-pointer bg-transparent border-none p-0' %>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- General Info -->
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-4 flex items-center gap-2">
          <span>General Information</span>
        </h2>
        <div class="space-y-2 text-gray-700">
          <p><span class="font-medium text-gray-600">Appointment ID:</span> <%= @appointment.id %></p>
          <p>
            <span class="font-medium text-gray-600">Status:</span>
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                        <%= case @appointment.status
                            when 'completed' then 'bg-green-100 text-green-800'
                            when 'cancelled' then 'bg-red-100 text-red-800'
                            when 'pending' then 'bg-yellow-100 text-yellow-800'
                            else 'bg-gray-100 text-gray-800'
                            end %>">
              <%= @appointment.status.titleize %>
            </span>
          </p>
          <p><span class="font-medium text-gray-600">Start Time:</span> <%= @appointment.start_time.strftime("%b %d, %Y %H:%M") %></p>
          <p><span class="font-medium text-gray-600">End Time:</span> <%= @appointment.end_time.strftime("%b %d, %Y %H:%M") %></p>
        </div>
      </div>

      <!-- Doctor Info -->
      <div class="bg-white rounded-xl border border-gray-100 shadow-sm p-6">
        <h2 class="text-lg font-semibold text-gray-800 mb-4 flex items-center gap-2">
          <span>Doctor Information</span>
        </h2>
        <div class="space-y-2 text-gray-700">
          <p><span class="font-medium text-gray-600">Name:</span> <%= @appointment.doctor.full_name %></p>
        </div>
      </div>
    </div>
  </div>
</div>
