# Database Configuration
DATABASE_URL=postgres://postgres:postgres@video_calls_db:5432/video_calls_development

# Redis Configuration
REDIS_URL=redis://localhost:6379/5

# Rails Configuration
RAILS_ENV=development

# Authentication
APP_SECRET_KEY=your_app_secret_key_here

# Service URLs
