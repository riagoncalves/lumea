<div class="min-h-screen bg-gradient-to-b from-gray-50 to-gray-100 px-6 py-10">
  <div class="max-w-6xl mx-auto bg-white/80 backdrop-blur-sm shadow-xl rounded-2xl border border-gray-100 p-8">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <h1 class="text-3xl font-semibold text-gray-800">Patients</h1>
    </div>

    <div class="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
      <table class="min-w-full text-sm text-left text-gray-700">
        <thead class="bg-gray-100 text-gray-600 uppercase text-xs font-semibold tracking-wide">
          <tr>
            <th class="px-5 py-3">Name</th>
            <th class="px-5 py-3">Actions</th>
          </tr>
        </thead>

        <tbody class="divide-y divide-gray-200 bg-white">
          <% if @patients.present? %>
            <% @patients.each do |patient| %>
              <tr class="hover:bg-gray-50 transition-colors duration-150">
                <td class="px-5 py-3 whitespace-nowrap"><%= patient.full_name %></td>
                <td class="px-5 py-3 space-x-3">
                  <%= link_to 'View', doctor_patient_path(patient.id),
                      class: 'text-blue-600 hover:text-blue-800 font-medium transition-colors' %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="2" class="px-5 py-3 text-center text-gray-600">No patients found.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
