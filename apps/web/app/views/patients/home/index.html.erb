<div class="min-h-screen py-10 px-4">
  <div class="max-w-6xl mx-auto space-y-10">
    <!-- Header -->
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-3xl font-semibold text-gray-900">Welcome back, <%= @current_patient.full_name %> 👋</h1>
        <p class="text-gray-600 mt-1">Here’s an overview of your health journey.</p>
      </div>
      <%= link_to 'View Profile',
          patient_profile_path,
          class: 'px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-medium shadow-sm transition-all duration-200' %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white/80 backdrop-blur-sm border border-gray-100 shadow-md rounded-2xl p-6 flex flex-col justify-between">
        <div>
          <h2 class="text-lg font-semibold text-gray-800">Book Appointment</h2>
          <p class="text-gray-600 mt-2">Schedule a consultation with your doctor.</p>
        </div>
        <%= link_to 'Book Now',
            patient_new_appointment_path,
            class: 'mt-4 px-4 py-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl font-medium shadow-sm transition-all duration-200' %>
      </div>

      <div class="bg-white/80 backdrop-blur-sm border border-gray-100 shadow-md rounded-2xl p-6 flex flex-col justify-between">
        <div>
          <h2 class="text-lg font-semibold text-gray-800">Upcoming Sessions</h2>
          <p class="text-gray-600 mt-2">Check your scheduled appointments.</p>
        </div>
        <%= link_to 'View Appointments',
            patient_appointments_path,
            class: 'mt-4 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-medium shadow-sm transition-all duration-200' %>
      </div>
    </div>

    <div class="bg-white/80 backdrop-blur-sm border border-gray-100 shadow-lg rounded-2xl p-8 flex items-center justify-between">
      <div>
        <h2 class="text-2xl font-semibold text-gray-900">Take care of yourself 🌿</h2>
        <p class="text-gray-600 mt-2">Remember — your health journey is built one step at a time.</p>
      </div>
      <%= link_to 'Book a Checkup',
          patient_new_appointment_path,
          class: 'px-6 py-2.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded-xl font-medium shadow-sm transition-all duration-200' %>
    </div>
  </div>
</div>
