<nav class="bg-white border-b border-gray-200 shadow-sm">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <div class="flex items-center space-x-6">
        <% if patient? || doctor? %>
          <% if patient? %>
            <%= link_to 'Dashboard', patient_home_path, class: 'text-gray-700 font-medium hover:text-blue-600 transition-colors duration-200' %>
            <%= link_to 'Profile', patient_profile_path, class: 'text-gray-700 font-medium hover:text-blue-600 transition-colors duration-200' %>
            <%= link_to 'Appointments', patient_appointments_path, class: 'text-gray-700 font-medium hover:text-blue-600 transition-colors duration-200' %>
            <%= button_to 'Logout', logout_path,
                        method: :delete,
                        class: 'text-red-600 font-medium hover:text-red-700 transition-colors duration-200' %>
          <% elsif doctor? %>
            <%= link_to 'Dashboard', doctor_home_path, class: 'text-gray-700 font-medium hover:text-blue-600 transition-colors duration-200' %>
            <%= link_to 'Profile', doctor_profile_path, class: 'text-gray-700 font-medium hover:text-blue-600 transition-colors duration-200' %>
            <%= link_to 'Patients', doctor_patients_path, class: 'text-gray-700 font-medium hover:text-blue-600 transition-colors duration-200' %>
            <%= link_to 'Appointments', doctor_appointments_path, class: 'text-gray-700 font-medium hover:text-blue-600 transition-colors duration-200' %>
            <%= button_to 'Logout', doctor_logout_path,
                        method: :delete,
                        class: 'text-red-600 font-medium hover:text-red-700 transition-colors duration-200' %>
          <% end %>
        <% else %>
          <%= link_to 'Login', login_path, class: 'text-gray-700 font-medium hover:text-blue-600 transition-colors duration-200' %>
          <%= link_to 'Sign Up', register_path, class: 'text-white bg-blue-600 hover:bg-blue-700 font-medium rounded-lg px-4 py-2 transition-colors duration-200' %>
        <% end %>
      </div>
    </div>
  </div>
</nav>
