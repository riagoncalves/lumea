<!DOCTYPE html>
<html lang="en">
  <head>
    <%= render 'shared/seo_tags' %>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body class="min-h-screen flex flex-col bg-gray-50 text-gray-900 antialiased">
    <%= render 'shared/navbar' %>

    <div class="flex-1 w-full mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <%= render 'shared/flash_messages', flash: flash %>
      <main class="py-8">
        <%= yield %>
      </main>
    </div>

    <footer class="border-t border-gray-200 bg-white py-4 text-center text-sm text-gray-500">
      <p>&copy; Lumea <%= Time.current.year %> — All rights reserved.</p>
    </footer>
  </body>
</html>
