<div class="max-w-5xl mx-auto bg-white shadow-lg rounded-2xl p-8 space-y-8">
  <!-- Header -->
  <div class="flex justify-between items-center border-b border-gray-100 pb-4">
    <h1 class="text-3xl font-bold text-gray-900">Appointment</h1>
    <%= link_to 'Back',
        patient_appointments_path,
        class: 'inline-flex items-center bg-gray-100 hover:bg-gray-200 text-gray-700 font-medium px-4 py-2 rounded-lg transition' %>
  </div>

  <!-- Doctor Info -->
  <section class="bg-gray-50 p-5 rounded-xl border border-gray-200">
    <h2 class="text-lg font-semibold text-gray-800 mb-2">Doctor Information</h2>
    <p class="text-gray-700">
      <span class="font-medium text-gray-600">Name:</span>
      <%= @appointment.doctor&.full_name || 'Unavailable' %>
    </p>
  </section>

  <!-- Video Call Section -->
  <section
    data-controller="video-call"
    data-video-call-room-name-value="<%= @video_room.name %>"
    data-video-call-access-token-value="<%= @video_room.access_token %>"
    class="space-y-4">

    <h2 class="text-xl font-semibold text-gray-800">Video Call</h2>

    <!-- Video Container -->
    <div class="relative bg-gray-900 rounded-2xl overflow-hidden aspect-video flex justify-center items-center">
      <!-- Remote Video -->
      <div id="remote-video" class="w-full h-full flex justify-center items-center text-gray-400 text-lg">
        Waiting for participant...
      </div>

      <!-- Local Video Overlay -->
      <div
        id="local-video"
        class="absolute bottom-4 right-4 w-48 h-36 rounded-lg overflow-hidden shadow-lg border border-gray-700 bg-gray-800">
      </div>
    </div>

    <!-- Control Buttons -->
    <div class="flex justify-center space-x-4 mt-2">
      <button
        data-action="click->video-call#join"
        class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold transition">
        Join Call
      </button>

      <button
        data-action="click->video-call#leave"
        class="px-6 py-2.5 bg-red-600 hover:bg-red-700 text-white rounded-lg font-semibold transition">
        Leave
      </button>
    </div>
  </section>
</div>
