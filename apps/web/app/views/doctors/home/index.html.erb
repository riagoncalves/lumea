<div class="min-h-screen py-10 px-4">
  <div class="max-w-6xl mx-auto space-y-10">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-3xl font-semibold text-gray-900">Good day, Dr. <%= @current_doctor.full_name %> 👨‍⚕️</h1>
        <p class="text-gray-600 mt-1">Here’s your quick overview for today.</p>
      </div>
      <%= link_to 'View Profile',
          doctor_profile_path,
          class: 'px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-medium shadow-sm transition-all duration-200' %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="bg-white/80 backdrop-blur-sm border border-gray-100 shadow-md rounded-2xl p-6 flex flex-col justify-between">
        <div>
          <h2 class="text-lg font-semibold text-gray-800">Today's Appointments</h2>
          <p class="text-gray-600 mt-2">Review and manage your scheduled sessions.</p>
        </div>
        <%= link_to 'Go to Appointments',
            doctor_appointments_path,
            class: 'mt-4 px-4 py-2 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-medium shadow-sm transition-all duration-200' %>
      </div>

      <div class="bg-white/80 backdrop-blur-sm border border-gray-100 shadow-md rounded-2xl p-6 flex flex-col justify-between">
        <div>
          <h2 class="text-lg font-semibold text-gray-800">Patient Details</h2>
          <p class="text-gray-600 mt-2">Access and review your patients’ information.</p>
        </div>
        <%= link_to 'View Patients',
            doctor_patients_path,
            class: 'mt-4 px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-800 rounded-xl font-medium transition-all duration-200' %>
      </div>
    </div>

    <div class="bg-white/80 backdrop-blur-sm border border-gray-100 shadow-lg rounded-2xl p-8 flex items-center justify-between">
      <div>
        <h2 class="text-2xl font-semibold text-gray-900">Ready for another productive day?</h2>
        <p class="text-gray-600 mt-2">You’re doing great work helping patients every day. 💪</p>
      </div>
      <%= link_to 'Start Now',
          doctor_appointments_path,
          class: 'px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-medium shadow-sm transition-all duration-200' %>
    </div>
  </div>
</div>
