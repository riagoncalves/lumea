<nav class="bg-gray-100 border-b border-gray-200 px-6 py-4 flex justify-between items-center">
  <div class="flex items-center space-x-4">
    <% if patient? %>
      <%= link_to 'Dashboard', patient_home_path, class: 'text-blue-600 hover:text-blue-800' %>
      <%= link_to 'My Profile', patient_profile_path, class: 'text-blue-600 hover:text-blue-800' %>
      <%= link_to 'Logout', logout_path, method: :delete, class: 'text-red-600 hover:text-red-800' %>
    <% elsif doctor? %>
      <%= link_to 'Dashboard', doctor_home_path, class: 'text-blue-600 hover:text-blue-800' %>
      <%= link_to 'Logout', logout_path, method: :delete, class: 'text-red-600 hover:text-red-800' %>
    <% else %>
      <%= link_to 'Login', login_path, class: 'text-blue-600 hover:text-blue-800' %>
      <%= link_to 'Sign Up', register_path, class: 'text-green-600 hover:text-green-800' %>
    <% end %>
  </div>
</nav>
