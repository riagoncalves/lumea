<div class="min-h-screen py-10 px-4">
  <div class="max-w-3xl mx-auto bg-white/80 backdrop-blur-sm border border-gray-100 shadow-xl rounded-2xl p-8 space-y-8">
    <!-- Header -->
    <div class="flex justify-between items-center">
      <h1 class="text-3xl font-semibold text-gray-900">Patient Details</h1>
      <%= link_to 'Back',
          doctor_patients_path,
          class: 'bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium px-4 py-2 rounded-xl transition-all duration-200 shadow-sm' %>
    </div>

    <% if @patient.present? %>
      <div class="bg-gray-50/80 p-6 rounded-xl border border-gray-200 shadow-sm space-y-4">
        <div class="flex items-center justify-between">
          <h2 class="text-2xl font-semibold text-gray-900"><%= @patient.full_name %></h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-gray-700">
          <div>
            <p class="font-medium text-gray-600">Gender</p>
            <p><%= @patient.gender.presence || "N/A" %></p>
          </div>
          <div>
            <p class="font-medium text-gray-600">Date of Birth</p>
            <p><%= @patient.date_of_birth&.strftime("%B %d, %Y") || "N/A" %></p>
          </div>
          <div>
            <p class="font-medium text-gray-600">Contact Number</p>
            <p><%= @patient.contact_number.presence || "N/A" %></p>
          </div>
          <div>
            <p class="font-medium text-gray-600">Address</p>
            <p><%= @patient.address.presence || "N/A" %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
