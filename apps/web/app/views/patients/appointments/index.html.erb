<div class="flex justify-between items-center mb-4">
  <h1 class="text-2xl font-bold text-gray-800">Appointments</h1>
  <%= link_to 'New Appointment', patient_new_appointment_path, class: 'bg-blue-600 hover:bg-blue-700 text-white font-semibold px-4 py-2 rounded shadow' %>
</div>

<div class="overflow-x-auto">
  <table class="min-w-full bg-white border border-gray-200 rounded-lg">
    <thead class="bg-gray-100">
      <tr>
        <th class="px-4 py-2 text-left text-gray-600 uppercase text-sm">Start Time</th>
        <th class="px-4 py-2 text-left text-gray-600 uppercase text-sm">End Time</th>
        <th class="px-4 py-2 text-left text-gray-600 uppercase text-sm">Status</th>
        <th class="px-4 py-2 text-left text-gray-600 uppercase text-sm">Doctor</th>
        <th class="px-4 py-2 text-left text-gray-600 uppercase text-sm">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-gray-200">
      <% @appointments.each do |appointment| %>
        <tr>
          <td class="px-4 py-2 text-gray-700"><%= appointment.start_time.strftime("%b %d, %Y %H:%M") %></td>
          <td class="px-4 py-2 text-gray-700"><%= appointment.end_time.strftime("%b %d, %Y %H:%M") %></td>
          <td class="px-4 py-2"><%= appointment.status.titleize %></td>
          <td class="px-4 py-2 text-gray-700"><%= appointment.doctor.full_name %></td>
          <td class="px-4 py-2 space-x-2">
            <%= link_to 'View', patient_appointment_path(appointment.id), class: 'text-blue-600 hover:text-blue-800' %>
            <% if appointment.can_be_edited? %>
              <%= link_to 'Edit', patient_edit_appointment_path(appointment.id), class: 'text-yellow-600 hover:text-yellow-800' %>
              <%= button_to 'Cancel', patient_cancel_appointment_path(appointment.id),
                method: :delete,
                data: { turbo_confirm: 'Are you sure?' },
                class: 'text-red-600 hover:text-red-800 bg-transparent border-none p-0 underline cursor-pointer' %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
