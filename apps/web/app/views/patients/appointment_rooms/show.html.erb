<div class="max-w-4xl mx-auto bg-white shadow rounded-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Appointment</h1>
    <div class="space-x-2">
      <%= link_to 'Back', patient_appointments_path, class: 'bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold px-4 py-2 rounded' %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <h2 class="text-lg font-semibold text-gray-700 mb-2">Doctor Information</h2>
      <div class="space-y-2">
        <p>
          <span class="font-medium text-gray-600">Name:</span>
          <%= @appointment.doctor.full_name %>
        </p>
      </div>
    </div>
  </div>

  <div
    class="mt-8 border-t pt-6"
    data-controller="video-call"
    data-video-call-room-name-value="<%= @video_room.name %>"
    data-video-call-access-token-value="<%= @video_room.access_token %>">

    <h2 class="text-lg font-semibold text-gray-700 mb-4">Video Call</h2>

    <div class="flex items-center space-x-3 mb-4">
      <button
        data-action="click->video-call#join"
        class="px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 cursor-pointer">
        Start Video Call
      </button>

      <button
        data-action="click->video-call#leave"
        class="px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 cursor-pointer">
        Leave Call
      </button>
    </div>

    <div class="flex space-x-4">
      <div id="local-video" class="border rounded w-64 h-48 bg-gray-100"></div>
      <div id="remote-video" class="border rounded w-96 h-64 bg-gray-100"></div>
    </div>
  </div>
</div>
