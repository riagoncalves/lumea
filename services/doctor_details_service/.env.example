# Database Configuration
DATABASE_URL=postgres://postgres:postgres@doctor_details_db:5432/doctor_details_development

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Rails Configuration
RAILS_ENV=development

# Authentication
APP_SECRET_KEY=your_app_secret_key_here

# Service URLs
USERS_SERVICE_URL=http://localhost:3005
APPOINTMENTS_SERVICE_URL=http://localhost:3001/api/external_services
COMMUNICATIONS_SERVICE_URL=http://localhost:3002
VIDEO_CALLS_SERVICE_URL=http://localhost:3006
LOG_SERVICE_URL=http://localhost:3003/api

# AWS S3 Configuration (for file uploads)
AWS_S3_BUCKET=your_s3_bucket
AWS_REGION=your_aws_region
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
