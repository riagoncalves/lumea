<div class="max-w-5xl mx-auto bg-white shadow rounded-xl p-6 space-y-6">
  <!-- Header -->
  <div class="flex justify-between items-center">
    <h1 class="text-2xl font-bold text-gray-900">Appointment</h1>
    <%= link_to 'Back', doctor_appointments_path, class: 'bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold px-4 py-2 rounded' %>
  </div>

  <!-- Doctor Info -->
  <div class="bg-gray-50 p-4 rounded-lg border border-gray-200">
    <h2 class="text-lg font-semibold text-gray-800 mb-2">Doctor Information</h2>
    <p><span class="font-medium text-gray-600">Name:</span> <%= @appointment.doctor&.full_name %></p>
  </div>

  <!-- Video Call Section -->
  <div
    data-controller="video-call"
    data-video-call-room-name-value="<%= @video_room.name %>"
    data-video-call-access-token-value="<%= @video_room.access_token %>"
    class="space-y-4">

    <h2 class="text-xl font-semibold text-gray-800">Video Call</h2>

    <!-- Video Container -->
    <div class="relative bg-gray-900 rounded-xl overflow-hidden aspect-video flex justify-center items-center">
      <!-- Remote Video -->
      <div id="remote-video" class="w-full h-full flex justify-center items-center text-gray-400 text-lg">
        Waiting for participant...
      </div>

      <!-- Local Video Overlay -->
      <div id="local-video" class="absolute bottom-4 right-4 w-48 h-36 rounded-lg overflow-hidden shadow-lg border border-gray-700 bg-gray-800">
      </div>
    </div>

    <!-- Control Buttons -->
    <div class="flex justify-center space-x-4 mt-2">
      <button
        data-action="click->video-call#join"
        class="px-5 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-lg font-semibold transition">
        Join Call
      </button>

      <button
        data-action="click->video-call#leave"
        class="px-5 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg font-semibold transition">
        Leave
      </button>
    </div>
  </div>
</div>
