<div class="max-w-4xl mx-auto bg-white shadow rounded-lg p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Appointment Details</h1>
    <div class="space-x-2">
      <%= link_to 'Back', patient_appointments_path, class: 'bg-gray-200 hover:bg-gray-300 text-gray-700 font-semibold px-4 py-2 rounded' %>
      <% if @appointment.can_be_edited? %>
        <%= link_to 'Edit', patient_edit_appointment_path(@appointment.id), class: 'bg-yellow-500 hover:bg-yellow-600 text-white font-semibold px-4 py-2 rounded' %>
        <%= link_to 'Cancel', patient_cancel_appointment_path(@appointment.id), method: :delete, data: { confirm: 'Are you sure?' }, class: 'bg-red-600 hover:bg-red-700 text-white font-semibold px-4 py-2 rounded' %>
      <% end %>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <h2 class="text-lg font-semibold text-gray-700 mb-2">General Information</h2>
      <div class="space-y-2">
        <p><span class="font-medium text-gray-600">Appointment ID:</span> <%= @appointment.id %></p>
        <p><span class="font-medium text-gray-600">Status:</span> 
          <span class="<%= @appointment.status == 'completed' ? 'text-green-600' : @appointment.status == 'cancelled' ? 'text-red-600' : 'text-yellow-600' %> font-semibold">
            <%= @appointment.status.titleize %>
          </span>
        </p>
        <p><span class="font-medium text-gray-600">Start Time:</span> <%= @appointment.start_time.strftime("%b %d, %Y %H:%M") %></p>
        <p><span class="font-medium text-gray-600">End Time:</span> <%= @appointment.end_time.strftime("%b %d, %Y %H:%M") %></p>
      </div>
    </div>

    <div>
      <h2 class="text-lg font-semibold text-gray-700 mb-2">Doctor Information</h2>
      <div class="space-y-2">
        <p><span class="font-medium text-gray-600">Name:</span> <%= @appointment.doctor.full_name %></p>
      </div>
    </div>
  </div>
</div>
