<div class="min-h-screen bg-gradient-to-b from-gray-50 to-gray-100 py-10 px-4">
  <div class="max-w-5xl mx-auto bg-white/80 backdrop-blur-sm border border-gray-100 shadow-xl rounded-2xl p-8 space-y-8">
    <!-- Header -->
    <div class="flex justify-between items-center">
      <h1 class="text-3xl font-semibold text-gray-900">Appointment</h1>
      <div class="flex items-center space-x-3">
        <%= button_to 'Complete',
            doctor_complete_appointment_path(@appointment.id),
            method: :put,
            data: { turbo_confirm: 'Are you sure you want to complete this appointment?' },
            class: 'bg-green-600 hover:bg-green-700 text-white font-medium px-4 py-2 rounded-xl transition-all duration-200 shadow-sm' %>

        <%= link_to 'Back',
            doctor_appointments_path,
            class: 'bg-gray-200 hover:bg-gray-300 text-gray-700 font-medium px-4 py-2 rounded-xl transition-all duration-200 shadow-sm' %>
      </div>
    </div>

    <!-- Patient Info -->
    <div class="bg-gray-50/80 p-5 rounded-xl border border-gray-200 shadow-sm">
      <h2 class="text-lg font-semibold text-gray-800 mb-3">Patient Information</h2>
      <p class="text-gray-700"><span class="font-medium text-gray-600">Name:</span> <%= @appointment.patient&.full_name %></p>
    </div>

    <!-- Video Call Section -->
    <div
      data-controller="video-call"
      data-video-call-room-name-value="<%= @video_room.name %>"
      data-video-call-access-token-value="<%= @video_room.access_token %>"
      class="space-y-6">

      <h2 class="text-2xl font-semibold text-gray-900">Video Call</h2>

      <!-- Video Container -->
      <div class="relative bg-gray-900 rounded-2xl overflow-hidden aspect-video flex justify-center items-center border border-gray-800 shadow-lg">
        <!-- Remote Video -->
        <div id="remote-video" class="w-full h-full flex justify-center items-center text-gray-400 text-lg font-medium">
          Waiting for participant...
        </div>

        <!-- Local Video Overlay -->
        <div id="local-video"
             class="absolute bottom-5 right-5 w-48 h-36 rounded-lg overflow-hidden shadow-2xl border border-gray-700 bg-gray-800">
        </div>
      </div>

      <!-- Control Buttons -->
      <div class="flex justify-center space-x-4 mt-4">
        <button
          data-action="click->video-call#join"
          class="px-6 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-medium shadow-sm transition-all duration-200">
          Join Call
        </button>

        <button
          data-action="click->video-call#leave"
          class="px-6 py-2.5 bg-red-600 hover:bg-red-700 text-white rounded-xl font-medium shadow-sm transition-all duration-200">
          Leave
        </button>
      </div>
    </div>
  </div>
</div>
